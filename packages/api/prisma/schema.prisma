generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 서비스 (멀티 서비스 지원)
// ============================================
enum ServiceType {
  STANDARD    // 일반 서비스: x-service-id, x-user-id, x-dept-name 필수
  BACKGROUND  // 백그라운드 서비스: x-service-id, x-dept-name만 필수
}

enum ServiceStatus {
  DEVELOPMENT  // 개발 중 (생성 시 기본)
  DEPLOYED     // 배포 완료 (서비스 목록에 노출)
}

enum DeployScope {
  ALL            // 전체 공개
  BUSINESS_UNIT  // 사업부 공개
  TEAM           // 팀 공개
}

model Service {
  id          String        @id @default(uuid())
  name        String        @unique              // "my-service" (유니크, 등록시 중복체크)
  displayName String        @unique              // "My Service" (유니크, 중복 불가)
  description String?
  iconUrl     String?       @map("icon_url")
  docsUrl     String?       @map("docs_url")        // 서비스 설명서 URL
  serviceUrl  String?       @map("service_url")     // 서비스 바로가기 URL
  enabled     Boolean       @default(true)
  type        ServiceType   @default(STANDARD)
  status      ServiceStatus @default(DEVELOPMENT)   // 개발/배포 상태
  deployScope DeployScope   @default(ALL) @map("deploy_scope")  // 배포 공개 범위
  deployScopeValue String[] @default([]) @map("deploy_scope_value") // 공개 대상 (BU명, 팀명 등)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // 사업 정보
  targetMM      Float?    @map("target_mm")          // 목표 MM (men/month)
  savedMM       Float?    @map("saved_mm")            // 절감 실적 MM (현재 달성 M/M)
  serviceCategory String[] @default([]) @map("service_category") // 7개 카테고리 중 복수 선택
  standardMD    Float?    @map("standard_md")         // Background 서비스 표준 공수 (M/D)
  jiraTicket    String?   @map("jira_ticket")          // Jira 티켓 URL (optional)

  // API Only: 프록시를 통하지 않고 자체 API로 사용 기록을 직접 전송하는 서비스
  apiOnly     Boolean   @default(false) @map("api_only")

  // 등록한 사용자 정보 (누구나 서비스 생성 가능)
  registeredBy             String?  @map("registered_by")              // loginid
  registeredByDept         String?  @map("registered_by_dept")         // deptname (한글)
  registeredByBusinessUnit String?  @map("registered_by_business_unit") // BU

  // 등록자 조직 계층 (영문)
  team        String?  @map("team")          // 영문 팀 이름 (enDepartmentName)
  center2Name String?  @map("center_2_name") // 1차 상위부서 영문 (immediate parent)
  center1Name String?  @map("center_1_name") // 2차 상위부서 영문 (grandparent)

  // Relations
  usageLogs           UsageLog[]
  ratingFeedbacks     RatingFeedback[]
  userServices        UserService[]
  rateLimits          UserRateLimit[]
  serviceRateLimit    ServiceRateLimit?
  serviceModels       ServiceModel[]
  requestLogs         RequestLog[]
  aiEstimations       AiEstimation[]
  deptSavedMMs        DeptServiceSavedMM[]

  @@map("services")
}

// ============================================
// 사용자 모델
// ============================================
model User {
  id            String   @id @default(uuid())
  loginid        String   @unique
  username       String
  deptname       String   @default("")
  businessUnit   String?  @map("business_unit")
  enDeptName     String?  @map("en_dept_name")       // 영문 부서명 (Knox enDepartmentName)
  departmentCode String?  @map("department_code")    // Knox 부서코드
  knoxVerified   Boolean  @default(false) @map("knox_verified")
  firstSeen     DateTime @default(now())
  lastActive    DateTime @default(now())
  isActive      Boolean  @default(true)

  usageLogs       UsageLog[]
  userServices    UserService[]
  rateLimits      UserRateLimit[]

  @@map("users")
}

// ============================================
// Knox 임직원 인증 이력
// ============================================
model KnoxVerification {
  id              String   @id @default(uuid())
  loginid         String
  username        String   @default("")          // Knox API 에서 가져온 한글이름
  knoxDeptName    String   @default("") @map("knox_dept_name")   // Knox API 에서 가져온 부서명
  claimedDeptName String   @default("") @map("claimed_dept_name") // 요청 시 입력한 부서명 (x-dept-name)
  method          String                          // PROXY | DASHBOARD | ADMIN_REGISTER
  endpoint        String?                         // 접근 endpoint (e.g., /v1/chat/completions)
  success         Boolean  @default(true)
  errorMessage    String?  @map("error_message")
  ipAddress       String?  @map("ip_address")
  timestamp       DateTime @default(now())

  @@index([loginid])
  @@index([timestamp])
  @@index([success])
  @@map("knox_verifications")
}

// ============================================
// 사용자-서비스 활동 추적
// ============================================
model UserService {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  serviceId    String   @map("service_id")
  role         String   @default("USER") @map("role")  // OWNER, ADMIN, USER
  firstSeen    DateTime @map("first_seen")
  lastActive   DateTime @map("last_active")
  requestCount Int      @default(0) @map("request_count")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([serviceId])
  @@index([lastActive])
  @@map("user_services")
}

// ============================================
// LLM 모델 설정 (서비스와 독립)
// ============================================
enum LlmVisibility {
  PUBLIC            // 전체공개
  BUSINESS_UNIT     // 특정 사업부 공개
  TEAM              // 특정 팀 공개
  ADMIN_ONLY        // 모든 관리자 (admin + super admin)
  SUPER_ADMIN_ONLY  // 슈퍼 관리자만
}

enum ModelType {
  CHAT       // 채팅 완성 모델
  IMAGE      // 이미지 생성 모델
  EMBEDDING  // 임베딩 모델
  RERANKING  // 리랭킹 모델
  ASR        // 음성 인식 모델 (STT)
}

model Model {
  id          String   @id @default(uuid())
  name        String                           // 중복 허용 (동일 모델 ID, 다른 설정 가능)
  displayName String
  endpointUrl String
  apiKey      String?
  maxTokens   Int      @default(128000)
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now())
  createdBy   String?                          // FK to Admin.id

  // LLM 호출 시 추가 헤더/바디 (JSON object)
  extraHeaders Json? @map("extra_headers")
  extraBody    Json? @map("extra_body")

  // 모델 타입
  type          ModelType @default(CHAT) @map("model_type")
  imageProvider String?  @map("image_provider")  // IMAGE 타입: OPENAI, COMFYUI 등
  asrMethod     String?  @map("asr_method")      // ASR 타입: AUDIO_URL, OPENAI_TRANSCRIBE

  // Vision Language Model 지원 여부
  supportsVision Boolean @default(false) @map("supports_vision")

  // 공개 범위
  visibility      LlmVisibility @default(PUBLIC)
  visibilityScope String[]      @default([]) @map("visibility_scope")
  // PUBLIC: [] (전체), BUSINESS_UNIT: ["S.LSI","DS"], TEAM: ["S/W혁신팀(S.LSI)"], ADMIN_ONLY: []
  adminVisible    Boolean       @default(false) @map("admin_visible")
  // true: 팀/사업부 공개와 별도로 모든 관리자(ADMIN+SUPER_ADMIN)도 접근 가능

  // 등록한 admin 정보 (수정/삭제 권한 판단용)
  createdByDept         String? @map("created_by_dept")
  createdByBusinessUnit String? @map("created_by_business_unit")
  createdBySuperAdmin   Boolean @default(false) @map("created_by_super_admin")
  superAdminOnly        Boolean @default(false) @map("super_admin_only")

  creator               Admin?           @relation(fields: [createdBy], references: [id])
  usageLogs             UsageLog[]
  subModels             SubModel[]
  serviceModels         ServiceModel[]
  serviceModelFallbacks ServiceModel[]   @relation("ServiceModelFallback")
  healthChecks          HealthCheckLog[]

  @@map("models")
}

// ============================================
// 서비스-모델 연결 (서비스가 사용할 수 있는 LLM)
// ============================================
model ServiceModel {
  id              String   @id @default(uuid())
  serviceId       String   @map("service_id")
  modelId         String   @map("model_id")
  aliasName       String   @default("") @map("alias_name")        // v1/models에 표시될 가상 모델명
  sortOrder       Int      @default(0) @map("sort_order")       // 표시 순서
  weight          Int      @default(1) @map("weight")            // 라운드로빈 호출 횟수 (1~10)
  enabled         Boolean  @default(true)                         // 비활성화 시 라운드로빈 제외
  fallbackModelId String?  @map("fallback_model_id")             // 에러 시 호출할 폴백 모델 (alias 그룹 공유)
  maxRetries      Int      @default(0) @map("max_retries")      // 단일 엔드포인트 재시도 횟수 (0=재시도 안함)
  addedBy         String?  @map("added_by")     // 추가한 사용자 loginid
  addedAt         DateTime @default(now()) @map("added_at")

  service       Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  model         Model   @relation(fields: [modelId], references: [id], onDelete: Cascade)
  fallbackModel Model?  @relation("ServiceModelFallback", fields: [fallbackModelId], references: [id], onDelete: SetNull)

  @@unique([serviceId, modelId, aliasName])
  @@index([serviceId])
  @@index([modelId])
  @@map("service_models")
}

// ============================================
// 서브모델 (로드밸런싱용)
// ============================================
model SubModel {
  id          String   @id @default(uuid())
  parentId    String   @map("parent_id")
  modelName   String?  @map("model_name")
  endpointUrl String   @map("endpoint_url")
  apiKey      String?  @map("api_key")
  extraHeaders Json?   @map("extra_headers")
  extraBody    Json?   @map("extra_body")
  enabled     Boolean  @default(true)
  weight      Int      @default(1) @map("weight")       // 라운드로빈 가중치 (2=2배 빈도)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  parent Model @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@map("sub_models")
}

// ============================================
// 관리자 (3단계: SUPER_ADMIN / ADMIN)
// ============================================
enum AdminRole {
  SUPER_ADMIN  // 모든 권한
  ADMIN        // dept 내 권한
}

model Admin {
  id           String    @id @default(uuid())
  loginid      String    @unique
  role         AdminRole @default(ADMIN)
  deptname     String    @default("")
  businessUnit String?   @map("business_unit")
  designatedBy String?   @map("designated_by")  // 지정한 super admin loginid
  createdAt    DateTime  @default(now())

  models Model[]  // 등록한 모델들

  @@map("admins")
}

// ============================================
// 관리자 권한 신청
// ============================================
model AdminRequest {
  id           String   @id @default(uuid())
  loginid      String                                // 신청자
  username     String   @default("")                  // 신청자 이름 (한글)
  deptname     String   @default("")                  // 부서명
  businessUnit String?  @map("business_unit")         // 사업부
  titleName    String?  @map("title_name")            // 직급
  reason       String   @db.Text                      // 신청 사유
  status       String   @default("PENDING")           // PENDING / APPROVED / REJECTED
  reviewedBy   String?  @map("reviewed_by")           // 처리한 관리자 loginid
  reviewedAt   DateTime? @map("reviewed_at")          // 처리 일시
  reviewNote   String?  @map("review_note") @db.Text  // 거부 사유 등
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([loginid])
  @@index([status])
  @@index([createdAt])
  @@map("admin_requests")
}

// ============================================
// 사용 로그 (개별 요청)
// ============================================
model UsageLog {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")        // nullable: background 서비스는 user 없음
  modelId      String   @map("model_id")
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  requestCount Int      @default(1) @map("request_count")  // 외부 사용량: 요청 수, 프록시: 항상 1
  latencyMs    Int?     @map("latency_ms")
  timestamp    DateTime @default(now())
  deptname     String?                          // 요청 dept 추적

  // 서비스 연결
  serviceId String? @map("service_id")
  service   Service? @relation(fields: [serviceId], references: [id])

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  model Model @relation(fields: [modelId], references: [id])

  @@index([userId])
  @@index([modelId])
  @@index([timestamp])
  @@index([serviceId])
  @@index([deptname])
  @@index([userId, serviceId, timestamp])  // rate limit aggregate 최적화
  @@map("usage_logs")
}

// ============================================
// 휴일 관리
// ============================================
enum HolidayType {
  NATIONAL
  COMPANY
  CUSTOM
}

model Holiday {
  id        String      @id @default(uuid())
  date      DateTime    @db.Date @unique
  name      String
  type      HolidayType @default(NATIONAL)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([date])
  @@map("holidays")
}

// ============================================
// 사용자별 토큰 Rate Limit
// ============================================
enum RateLimitWindow {
  FIVE_HOURS  // 5시간 윈도우
  DAY         // 24시간 윈도우
}

model UserRateLimit {
  id         String          @id @default(uuid())
  userId     String          @map("user_id")
  serviceId  String          @map("service_id")
  maxTokens  Int             @map("max_tokens")       // 윈도우 내 최대 토큰
  window     RateLimitWindow @default(DAY)
  enabled    Boolean         @default(true)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  createdBy  String?         @map("created_by")       // 설정한 admin loginid

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([serviceId])
  @@map("user_rate_limits")
}

// ============================================
// 서비스 공통 Rate Limit (모든 사용자에게 동일 적용)
// ============================================
model ServiceRateLimit {
  id         String          @id @default(uuid())
  serviceId  String          @unique @map("service_id")
  maxTokens  Int             @map("max_tokens")       // 윈도우 내 인당 최대 토큰
  window     RateLimitWindow @default(DAY)
  enabled    Boolean         @default(true)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  createdBy  String?         @map("created_by")       // 설정한 admin loginid

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_rate_limits")
}

// ============================================
// 모델 평점 피드백 (1-5점)
// ============================================
model RatingFeedback {
  id        String   @id @default(uuid())
  modelName String   @map("model_name")
  rating    Int
  timestamp DateTime @default(now())

  serviceId String?  @map("service_id")
  service   Service? @relation(fields: [serviceId], references: [id])

  @@index([modelName])
  @@index([timestamp])
  @@index([serviceId])
  @@map("rating_feedbacks")
}

// ============================================
// 이미지 생성 결과 (로컬 저장 + 자동 만료)
// ============================================
model GeneratedImage {
  id         String   @id @default(uuid())
  fileName   String   @unique @map("file_name")
  mimeType   String   @default("image/png") @map("mime_type")
  sizeBytes  Int      @default(0) @map("size_bytes")
  modelId    String?  @map("model_id")
  userId     String?  @map("user_id")
  serviceId  String?  @map("service_id")
  prompt     String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime @map("expires_at")

  @@index([expiresAt])
  @@index([userId])
  @@index([modelId])
  @@map("generated_images")
}

// ============================================
// 요청 로그 (프록시 요청 상세)
// ============================================
model RequestLog {
  id            String   @id @default(uuid())
  serviceId     String?  @map("service_id")
  userId        String?  @map("user_id")
  deptname      String?
  modelName     String   @map("model_name")
  resolvedModel String?  @map("resolved_model")
  method        String
  path          String
  statusCode    Int      @map("status_code")
  inputTokens   Int?     @map("input_tokens")
  outputTokens  Int?     @map("output_tokens")
  latencyMs     Int?     @map("latency_ms")
  errorMessage  String?  @map("error_message")
  errorDetails  Json?    @map("error_details")   // 엔드포인트별 실패 상세 (failover 시도 이력)
  userAgent     String?  @map("user_agent")
  ipAddress     String?  @map("ip_address")
  stream        Boolean  @default(false)
  timestamp     DateTime @default(now())

  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([userId])
  @@index([modelName])
  @@index([statusCode])
  @@index([timestamp])
  @@index([userId, timestamp])
  @@index([statusCode, timestamp])
  @@map("request_logs")
}

// ============================================
// 감사 로그 (관리자 행동 기록)
// ============================================
model AuditLog {
  id         String   @id @default(uuid())
  adminId    String?  @map("admin_id")
  loginid    String
  action     String
  target     String?
  targetType String?  @map("target_type")
  details    Json?
  ipAddress  String?  @map("ip_address")
  timestamp  DateTime @default(now())

  @@index([adminId])
  @@index([loginid])
  @@index([action])
  @@index([timestamp])
  @@index([targetType])
  @@map("audit_logs")
}

// ============================================
// 부서 계층 캐시 (Knox Organization API 결과)
// ============================================
model DepartmentHierarchy {
  id              String   @id @default(uuid())
  departmentCode  String   @unique @map("department_code")   // Knox 부서코드 (캐시 키)
  departmentName  String   @map("department_name")            // 한글 부서명
  team            String                                      // 영문 팀이름 (enDepartmentName)
  center2Name     String   @map("center_2_name")              // 1차 상위부서 영문
  center1Name     String   @map("center_1_name")              // 2차 상위부서 영문
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("department_hierarchies")
}

// ============================================
// LLM 헬스체크 로그 (10분 주기 프로빙)
// ============================================
model HealthCheckLog {
  id          String   @id @default(uuid())
  modelId     String   @map("model_id")
  modelName   String   @map("model_name")
  endpointUrl String   @map("endpoint_url")
  latencyMs   Int?     @map("latency_ms")
  statusCode  Int?     @map("status_code")
  success     Boolean  @default(false)
  errorMessage String? @map("error_message")
  checkedAt   DateTime @default(now()) @map("checked_at")

  model Model @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([checkedAt])
  @@index([modelId, checkedAt])
  @@map("health_check_logs")
}

// ============================================
// 시스템 설정 (Key-Value)
// ============================================
model SystemSetting {
  key       String   @id                     // e.g. "SYSTEM_LLM_MODEL_ID"
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")      // loginid

  @@map("system_settings")
}

// ============================================
// AI 추정 (서비스별 일일 M/M 추정)
// ============================================
model AiEstimation {
  id             String   @id @default(uuid())
  serviceId      String   @map("service_id")
  date           DateTime @db.Date                   // 추정 대상 날짜
  estimatedMM    Float    @map("estimated_mm")       // AI 추정 M/M
  confidence     String   @default("MEDIUM")         // HIGH / MEDIUM / LOW
  reasoning      String   @db.Text                   // AI 근거 (한국어)
  dauUsed        Float    @map("dau_used")           // 입력한 DAU
  isEstimatedDau Boolean  @default(false) @map("is_estimated_dau")
  totalCalls     Int      @default(0) @map("total_calls")
  modelId        String   @map("model_id")           // 사용한 시스템 LLM ID
  createdAt      DateTime @default(now()) @map("created_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, date])
  @@index([serviceId])
  @@index([date])
  @@map("ai_estimations")
}

// ============================================
// 부서별 서비스 Saved M/M (부서-서비스 단위 절감 실적)
// ============================================
model DeptServiceSavedMM {
  id            String   @id @default(uuid())
  serviceId     String   @map("service_id")
  deptname      String                               // 한글 부서명 (admin.deptname, user.deptname 매칭)
  savedMM       Float?   @map("saved_mm")             // 수기 입력 Saved M/M
  reason        String?  @db.Text                     // 입력 사유/근거
  aiEstimatedMM Float?   @map("ai_estimated_mm")      // AI 추정 M/M (부서+서비스 단위)
  aiConfidence  String?  @map("ai_confidence")        // HIGH / MEDIUM / LOW
  aiReasoning   String?  @map("ai_reasoning") @db.Text // AI 추정 근거
  updatedBy     String?  @map("updated_by")           // 마지막 수정자 loginid
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdAt     DateTime @default(now()) @map("created_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, deptname])
  @@index([serviceId])
  @@index([deptname])
  @@map("dept_service_saved_mm")
}

// ============================================
// DT GPU Power Usage (일자별 전력 사용률)
// ============================================
model GpuPowerUsage {
  id                 String   @id @default(uuid())
  date               DateTime @db.Date @unique          // 집계 날짜
  powerAvgUsageRatio Float    @map("power_avg_usage_ratio") // 평균 전력 사용률 (%)
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([date])
  @@map("gpu_power_usages")
}

// ============================================
// GPU 서버 모니터링 (SSH 기반)
// ============================================
model GpuServer {
  id              String   @id @default(uuid())
  name            String   @unique                          // 표시 이름 (예: "GPU서버-1")
  host            String                                    // IP 주소 또는 hostname
  sshPort         Int      @default(22) @map("ssh_port")
  sshUsername      String   @map("ssh_username")
  sshPassword     String   @map("ssh_password")             // AES-256-GCM 암호화
  description     String?
  isLocal         Boolean  @default(false) @map("is_local") // 대시보드 서버 자체인 경우
  enabled         Boolean  @default(true)
  pollIntervalSec Int      @default(60) @map("poll_interval_sec")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  snapshots GpuMetricSnapshot[]

  @@map("gpu_servers")
}

model GpuMetricSnapshot {
  id               String   @id @default(uuid())
  serverId         String   @map("server_id")
  timestamp        DateTime @default(now())

  // GPU 메트릭 (JSON 배열: [{index, uuid, name, memTotalMb, memUsedMb, utilGpu, utilMem, temp, powerW, powerMaxW}])
  gpuMetrics       Json     @map("gpu_metrics")

  // 시스템 메트릭
  cpuLoadAvg       Float?   @map("cpu_load_avg")       // 1분 로드 평균
  cpuCores         Int?     @map("cpu_cores")           // CPU 코어 수
  memoryTotalMb    Float?   @map("memory_total_mb")
  memoryUsedMb     Float?   @map("memory_used_mb")
  hostname         String?

  // GPU 프로세스 (JSON 배열: [{gpuIndex, pid, name, memMb, isLlm}])
  gpuProcesses     Json?    @map("gpu_processes")

  server GpuServer @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, timestamp])
  @@index([timestamp])
  @@map("gpu_metric_snapshots")
}

// ============================================
// 조직도 트리 노드 (Knox Organization API 기반)
// ============================================
model OrgNode {
  id                    String   @id @default(uuid())
  departmentCode        String   @unique @map("department_code")        // Knox 부서코드
  departmentName        String   @map("department_name")                // 한글 부서명
  enDepartmentName      String   @map("en_department_name")             // 영문 부서명
  parentDepartmentCode  String?  @map("parent_department_code")         // 상위 부서코드 (null = root)
  departmentLevel       String?  @map("department_level")               // 부서 레벨
  companyCode           String?  @map("company_code")
  managerId             String?  @map("manager_id")                     // 부서장 ID
  managerName           String?  @map("manager_name")                   // 부서장 성명
  hasChildren           Boolean  @default(false) @map("has_children")   // 하위부서 존재 여부
  userCount             Int      @default(0) @map("user_count")         // 이 부서 소속 시스템 사용자 수
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([parentDepartmentCode])
  @@map("org_nodes")
}

