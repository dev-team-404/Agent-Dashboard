generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 서비스 (멀티 서비스 지원)
// ============================================
enum ServiceType {
  STANDARD    // 일반 서비스: x-service-id, x-user-id, x-dept-name 필수
  BACKGROUND  // 백그라운드 서비스: x-service-id, x-dept-name만 필수
}

enum ServiceStatus {
  DEVELOPMENT  // 개발 중 (생성 시 기본)
  DEPLOYED     // 배포 완료 (서비스 마켓에 노출)
}

model Service {
  id          String        @id @default(uuid())
  name        String        @unique              // "my-service" (유니크, 등록시 중복체크)
  displayName String                             // "My Service"
  description String?
  iconUrl     String?       @map("icon_url")
  docsUrl     String?       @map("docs_url")        // 서비스 설명서 URL
  enabled     Boolean       @default(true)
  type        ServiceType   @default(STANDARD)
  status      ServiceStatus @default(DEVELOPMENT)   // 개발/배포 상태
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // 등록한 사용자 정보 (누구나 서비스 생성 가능)
  registeredBy             String?  @map("registered_by")              // loginid
  registeredByDept         String?  @map("registered_by_dept")         // deptname
  registeredByBusinessUnit String?  @map("registered_by_business_unit") // BU

  // Relations
  usageLogs        UsageLog[]
  dailyUsageStats  DailyUsageStat[]
  ratingFeedbacks  RatingFeedback[]
  userServices     UserService[]
  rateLimits       UserRateLimit[]
  serviceRateLimit ServiceRateLimit?
  serviceModels    ServiceModel[]
  requestLogs      RequestLog[]

  @@map("services")
}

// ============================================
// 사용자 모델
// ============================================
model User {
  id           String   @id @default(uuid())
  loginid      String   @unique
  username     String
  deptname     String   @default("")
  businessUnit String?  @map("business_unit")
  firstSeen    DateTime @default(now())
  lastActive   DateTime @default(now())
  isActive     Boolean  @default(true)

  usageLogs       UsageLog[]
  dailyUsageStats DailyUsageStat[]
  userServices    UserService[]
  rateLimits      UserRateLimit[]

  @@map("users")
}

// ============================================
// 사용자-서비스 활동 추적
// ============================================
model UserService {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  serviceId    String   @map("service_id")
  role         String   @default("USER") @map("role")  // OWNER, ADMIN, USER
  firstSeen    DateTime @map("first_seen")
  lastActive   DateTime @map("last_active")
  requestCount Int      @default(0) @map("request_count")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([serviceId])
  @@index([lastActive])
  @@map("user_services")
}

// ============================================
// LLM 모델 설정 (서비스와 독립)
// ============================================
enum LlmVisibility {
  PUBLIC            // 전체공개
  BUSINESS_UNIT     // 특정 사업부 공개
  TEAM              // 특정 팀 공개
  ADMIN_ONLY        // 모든 관리자 (admin + super admin)
  SUPER_ADMIN_ONLY  // 슈퍼 관리자만
}

enum ModelType {
  CHAT       // 채팅 완성 모델
  IMAGE      // 이미지 생성 모델
  EMBEDDING  // 임베딩 모델
  RERANKING  // 리랭킹 모델
}

model Model {
  id          String   @id @default(uuid())
  name        String                           // 중복 허용 (동일 모델 ID, 다른 설정 가능)
  displayName String
  endpointUrl String
  apiKey      String?
  maxTokens   Int      @default(128000)
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now())
  createdBy   String?                          // FK to Admin.id

  // LLM 호출 시 추가 헤더/바디 (JSON object)
  extraHeaders Json? @map("extra_headers")
  extraBody    Json? @map("extra_body")

  // 모델 타입
  type          ModelType @default(CHAT) @map("model_type")
  imageProvider String?  @map("image_provider")  // IMAGE 타입: OPENAI, COMFYUI 등

  // Vision Language Model 지원 여부
  supportsVision Boolean @default(false) @map("supports_vision")

  // 공개 범위
  visibility      LlmVisibility @default(PUBLIC)
  visibilityScope String[]      @default([]) @map("visibility_scope")
  // PUBLIC: [] (전체), BUSINESS_UNIT: ["S.LSI","DS"], TEAM: ["SW혁신팀(S.LSI)"], ADMIN_ONLY: []
  adminVisible    Boolean       @default(false) @map("admin_visible")
  // true: 팀/사업부 공개와 별도로 모든 관리자(ADMIN+SUPER_ADMIN)도 접근 가능

  // 등록한 admin 정보 (수정/삭제 권한 판단용)
  createdByDept         String? @map("created_by_dept")
  createdByBusinessUnit String? @map("created_by_business_unit")
  createdBySuperAdmin   Boolean @default(false) @map("created_by_super_admin")
  superAdminOnly        Boolean @default(false) @map("super_admin_only")

  creator         Admin?           @relation(fields: [createdBy], references: [id])
  usageLogs       UsageLog[]
  dailyUsageStats DailyUsageStat[]
  subModels       SubModel[]
  serviceModels   ServiceModel[]

  @@map("models")
}

// ============================================
// 서비스-모델 연결 (서비스가 사용할 수 있는 LLM)
// ============================================
model ServiceModel {
  id        String   @id @default(uuid())
  serviceId String   @map("service_id")
  modelId   String   @map("model_id")
  addedBy   String?  @map("added_by")     // 추가한 사용자 loginid
  addedAt   DateTime @default(now()) @map("added_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  model   Model   @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([serviceId, modelId])
  @@index([serviceId])
  @@index([modelId])
  @@map("service_models")
}

// ============================================
// 서브모델 (로드밸런싱용)
// ============================================
model SubModel {
  id          String   @id @default(uuid())
  parentId    String   @map("parent_id")
  modelName   String?  @map("model_name")
  endpointUrl String   @map("endpoint_url")
  apiKey      String?  @map("api_key")
  extraHeaders Json?   @map("extra_headers")
  extraBody    Json?   @map("extra_body")
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  parent Model @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@map("sub_models")
}

// ============================================
// 관리자 (3단계: SUPER_ADMIN / ADMIN)
// ============================================
enum AdminRole {
  SUPER_ADMIN  // 모든 권한
  ADMIN        // dept 내 권한
}

model Admin {
  id           String    @id @default(uuid())
  loginid      String    @unique
  role         AdminRole @default(ADMIN)
  deptname     String    @default("")
  businessUnit String?   @map("business_unit")
  designatedBy String?   @map("designated_by")  // 지정한 super admin loginid
  createdAt    DateTime  @default(now())

  models Model[]  // 등록한 모델들

  @@map("admins")
}

// ============================================
// 사용 로그 (개별 요청)
// ============================================
model UsageLog {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")        // nullable: background 서비스는 user 없음
  modelId      String   @map("model_id")
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  latencyMs    Int?     @map("latency_ms")
  timestamp    DateTime @default(now())
  deptname     String?                          // 요청 dept 추적

  // 서비스 연결
  serviceId String? @map("service_id")
  service   Service? @relation(fields: [serviceId], references: [id])

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  model Model @relation(fields: [modelId], references: [id])

  @@index([userId])
  @@index([modelId])
  @@index([timestamp])
  @@index([serviceId])
  @@index([deptname])
  @@index([userId, serviceId, timestamp])  // rate limit aggregate 최적화
  @@map("usage_logs")
}

// ============================================
// 일별 사용 통계 (집계)
// ============================================
model DailyUsageStat {
  id                String   @id @default(uuid())
  date              DateTime @db.Date
  userId            String?  @map("user_id")    // nullable: background
  modelId           String   @map("model_id")
  deptname          String   @default("")
  totalInputTokens  Int      @default(0)
  totalOutputTokens Int      @default(0)
  requestCount      Int      @default(0)

  serviceId String?  @map("service_id")
  service   Service? @relation(fields: [serviceId], references: [id])

  user  User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  model Model @relation(fields: [modelId], references: [id])

  @@unique([date, userId, modelId, serviceId])
  @@index([date])
  @@index([userId])
  @@index([modelId])
  @@index([serviceId])
  @@map("daily_usage_stats")
}

// ============================================
// 휴일 관리
// ============================================
enum HolidayType {
  NATIONAL
  COMPANY
  CUSTOM
}

model Holiday {
  id        String      @id @default(uuid())
  date      DateTime    @db.Date @unique
  name      String
  type      HolidayType @default(NATIONAL)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([date])
  @@map("holidays")
}

// ============================================
// 사용자별 토큰 Rate Limit
// ============================================
enum RateLimitWindow {
  FIVE_HOURS  // 5시간 윈도우
  DAY         // 24시간 윈도우
}

model UserRateLimit {
  id         String          @id @default(uuid())
  userId     String          @map("user_id")
  serviceId  String          @map("service_id")
  maxTokens  Int             @map("max_tokens")       // 윈도우 내 최대 토큰
  window     RateLimitWindow @default(DAY)
  enabled    Boolean         @default(true)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  createdBy  String?         @map("created_by")       // 설정한 admin loginid

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([serviceId])
  @@map("user_rate_limits")
}

// ============================================
// 서비스 공통 Rate Limit (모든 사용자에게 동일 적용)
// ============================================
model ServiceRateLimit {
  id         String          @id @default(uuid())
  serviceId  String          @unique @map("service_id")
  maxTokens  Int             @map("max_tokens")       // 윈도우 내 인당 최대 토큰
  window     RateLimitWindow @default(DAY)
  enabled    Boolean         @default(true)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  createdBy  String?         @map("created_by")       // 설정한 admin loginid

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_rate_limits")
}

// ============================================
// 모델 평점 피드백 (1-5점)
// ============================================
model RatingFeedback {
  id        String   @id @default(uuid())
  modelName String   @map("model_name")
  rating    Int
  timestamp DateTime @default(now())

  serviceId String?  @map("service_id")
  service   Service? @relation(fields: [serviceId], references: [id])

  @@index([modelName])
  @@index([timestamp])
  @@index([serviceId])
  @@map("rating_feedbacks")
}

// ============================================
// 이미지 생성 결과 (로컬 저장 + 자동 만료)
// ============================================
model GeneratedImage {
  id         String   @id @default(uuid())
  fileName   String   @unique @map("file_name")
  mimeType   String   @default("image/png") @map("mime_type")
  sizeBytes  Int      @default(0) @map("size_bytes")
  modelId    String?  @map("model_id")
  userId     String?  @map("user_id")
  serviceId  String?  @map("service_id")
  prompt     String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime @map("expires_at")

  @@index([expiresAt])
  @@index([userId])
  @@index([modelId])
  @@map("generated_images")
}

// ============================================
// 요청 로그 (프록시 요청 상세)
// ============================================
model RequestLog {
  id            String   @id @default(uuid())
  serviceId     String?  @map("service_id")
  userId        String?  @map("user_id")
  deptname      String?
  modelName     String   @map("model_name")
  resolvedModel String?  @map("resolved_model")
  method        String
  path          String
  statusCode    Int      @map("status_code")
  requestBody   String?  @map("request_body") @db.Text
  responseBody  String?  @map("response_body") @db.Text
  inputTokens   Int?     @map("input_tokens")
  outputTokens  Int?     @map("output_tokens")
  latencyMs     Int?     @map("latency_ms")
  errorMessage  String?  @map("error_message")
  userAgent     String?  @map("user_agent")
  ipAddress     String?  @map("ip_address")
  stream        Boolean  @default(false)
  timestamp     DateTime @default(now())

  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([userId])
  @@index([modelName])
  @@index([statusCode])
  @@index([timestamp])
  @@index([userId, timestamp])
  @@index([statusCode, timestamp])
  @@map("request_logs")
}

// ============================================
// 감사 로그 (관리자 행동 기록)
// ============================================
model AuditLog {
  id         String   @id @default(uuid())
  adminId    String?  @map("admin_id")
  loginid    String
  action     String
  target     String?
  targetType String?  @map("target_type")
  details    Json?
  ipAddress  String?  @map("ip_address")
  timestamp  DateTime @default(now())

  @@index([adminId])
  @@index([loginid])
  @@index([action])
  @@index([timestamp])
  @@index([targetType])
  @@map("audit_logs")
}
