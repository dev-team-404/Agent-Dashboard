# ============================================
# Agent Dashboard Configuration (v2)
# ============================================
# cp .env.example .env

# ============================================
# Server Configuration
# ============================================
SERVER_HOST=0.0.0.0
PROXY_PORT=8090
POSTGRES_PORT=8091
REDIS_PORT=8092
API_PORT=3000
DASHBOARD_PORT=80

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=nexuscoder
POSTGRES_USER=nexuscoder
POSTGRES_PASSWORD=nexuscoder123

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PASSWORD=

# ============================================
# Security Configuration
# ============================================
JWT_SECRET=your-jwt-secret-change-in-production
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ============================================
# Admin Configuration
# ============================================
# Super Admin (하드코딩: syngha.han, young87.kim, byeongju.lee)
# 추가 Super Admin은 아래에 쉼표로 구분하여 지정
DEVELOPERS=syngha.han,young87.kim,byeongju.lee

# ============================================
# SSO Configuration
# ============================================
SSO_BASE_URL=https://genai.samsungds.net:36810
SSO_CERT_PATH=/app/cert/cert.cer

# ============================================
# Proxy Configuration (내부망용)
# ============================================
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,.samsungds.net,postgres,redis,api,dashboard,nginx
NODE_TLS_REJECT_UNAUTHORIZED=0

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info
LOG_API_REQUESTS=true
