# ============================================
# Agent Registry Configuration (v2)
# ============================================
# cp .env.example .env

# ============================================
# Server Configuration
# ============================================
SERVER_HOST=0.0.0.0
PROXY_PORT=8090
POSTGRES_PORT=8091
REDIS_PORT=8092
API_PORT=3000
DASHBOARD_PORT=80

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=agent_stats
POSTGRES_USER=agent_stats
POSTGRES_PASSWORD=agent_stats_2026!

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PASSWORD=

# ============================================
# Security Configuration
# ============================================
JWT_SECRET=your-jwt-secret-change-in-production
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ============================================
# Admin Configuration
# ============================================
# Super Admin (하드코딩: syngha.han, young87.kim, byeongju.lee)
# 추가 Super Admin은 아래에 쉼표로 구분하여 지정
DEVELOPERS=syngha.han,young87.kim,byeongju.lee

# ============================================
# SSO Configuration
# ============================================
SSO_BASE_URL=https://genai.samsungds.net:36810
SSO_CERT_PATH=/app/cert/cert.cer

# ============================================
# Knox Employee API Configuration
# ============================================
KNOX_API_URL=https://openapi.samsung.net/employee/api/v2.0
KNOX_SYSTEM_ID=YOUR_SYSTEM_ID_HERE
KNOX_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE
KNOX_COMPANY_CODE=C10

# ============================================
# Proxy Configuration (내부망용)
# ============================================
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,.samsungds.net,postgres,redis,api,dashboard,nginx
NODE_TLS_REJECT_UNAUTHORIZED=0

# ============================================
# Dev Login (SSO 우회 — 테스트 환경에서만 사용)
# ============================================
# true로 설정하면 로그인 페이지에 Dev Login 입력창이 표시됨
# 주의: 운영 환경에서는 절대 활성화하지 마세요
ENABLE_DEV_LOGIN=

# ============================================
# Auth Server / OIDC Configuration
# ============================================
AUTH_PORT=9050
ENABLE_MOCK_SSO=false
SSO_ENABLED=true
SSO_CLIENT_ID=1ce2cced-d8b3-4bcf-887e-eaaa06e8d0f7
IDP_ENTITY_ID=https://stsds.secso.net/adfs/oauth2/authorize/
SSO_CERT_FILE=/app/cert/sso.cer
OIDC_ISSUER=https://{HOST_IP}:9050

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=info
LOG_API_REQUESTS=true
