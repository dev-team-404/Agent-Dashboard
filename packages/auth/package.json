{
  "name": "agent-platform-auth",
  "version": "1.0.0",
  "description": "OIDC Provider + Mock SSO for Agent Dashboard Platform",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:mock": "ENABLE_MOCK_SSO=true tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "gen-cert": "bash cert/generate-self-signed.sh",
    "decode": "tsx tools/decode-token.ts",
    "test-flow": "tsx tools/test-oidc-flow.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "cookie-parser": "^1.4.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "@types/cors": "^2.8.17",
    "@types/cookie-parser": "^1.4.7",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0"
  }
}
