generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 서비스 (멀티 서비스 지원)
// ============================================
enum ServiceType {
  STANDARD    // 일반 서비스: x-service-id, x-user-id, x-dept-name 필수
  BACKGROUND  // 백그라운드 서비스: x-service-id, x-dept-name만 필수
}

model Service {
  id          String      @id @default(uuid())
  name        String      @unique              // "my-service" (유니크, 등록시 중복체크)
  displayName String                           // "My Service"
  description String?
  iconUrl     String?     @map("icon_url")
  enabled     Boolean     @default(true)
  type        ServiceType @default(STANDARD)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // 등록한 admin 정보 (서비스는 등록 admin의 LLM 권한을 계승)
  registeredBy             String?  @map("registered_by")              // admin loginid
  registeredByDept         String?  @map("registered_by_dept")         // admin deptname
  registeredByBusinessUnit String?  @map("registered_by_business_unit") // admin BU

  // Relations
  usageLogs       UsageLog[]
  dailyUsageStats DailyUsageStat[]
  ratingFeedbacks RatingFeedback[]
  userServices    UserService[]
  rateLimits      UserRateLimit[]

  @@map("services")
}

// ============================================
// 사용자 모델
// ============================================
model User {
  id           String   @id @default(uuid())
  loginid      String   @unique
  username     String
  deptname     String   @default("")
  businessUnit String?  @map("business_unit")
  firstSeen    DateTime @default(now())
  lastActive   DateTime @default(now())
  isActive     Boolean  @default(true)

  usageLogs       UsageLog[]
  dailyUsageStats DailyUsageStat[]
  userServices    UserService[]
  rateLimits      UserRateLimit[]

  @@map("users")
}

// ============================================
// 사용자-서비스 활동 추적
// ============================================
model UserService {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  serviceId    String   @map("service_id")
  firstSeen    DateTime @map("first_seen")
  lastActive   DateTime @map("last_active")
  requestCount Int      @default(0) @map("request_count")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([serviceId])
  @@index([lastActive])
  @@map("user_services")
}

// ============================================
// LLM 모델 설정 (서비스와 독립)
// ============================================
enum LlmVisibility {
  PUBLIC         // 전체공개
  BUSINESS_UNIT  // 특정 사업부 공개
  TEAM           // 특정 팀 공개
  ADMIN_ONLY     // admin/super admin만
}

model Model {
  id          String   @id @default(uuid())
  name        String   @unique                // 전역 유니크
  displayName String
  endpointUrl String
  apiKey      String?
  maxTokens   Int      @default(128000)
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now())
  createdBy   String?                          // FK to Admin.id

  // LLM 호출 시 추가 헤더 (JSON object)
  extraHeaders Json? @map("extra_headers")

  // Vision Language Model 지원 여부
  supportsVision Boolean @default(false) @map("supports_vision")

  // 공개 범위 (4단계)
  visibility      LlmVisibility @default(PUBLIC)
  visibilityScope String[]      @default([]) @map("visibility_scope")
  // PUBLIC: [] (전체), BUSINESS_UNIT: ["S.LSI","DS"], TEAM: ["SW혁신팀(S.LSI)"], ADMIN_ONLY: []

  // 등록한 admin 정보 (수정/삭제 권한 판단용)
  createdByDept         String? @map("created_by_dept")
  createdByBusinessUnit String? @map("created_by_business_unit")
  createdBySuperAdmin   Boolean @default(false) @map("created_by_super_admin")

  creator         Admin?           @relation(fields: [createdBy], references: [id])
  usageLogs       UsageLog[]
  dailyUsageStats DailyUsageStat[]
  subModels       SubModel[]

  @@map("models")
}

// ============================================
// 서브모델 (로드밸런싱용)
// ============================================
model SubModel {
  id          String   @id @default(uuid())
  parentId    String   @map("parent_id")
  modelName   String?  @map("model_name")
  endpointUrl String   @map("endpoint_url")
  apiKey      String?  @map("api_key")
  extraHeaders Json?   @map("extra_headers")
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  parent Model @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@map("sub_models")
}

// ============================================
// 관리자 (3단계: SUPER_ADMIN / ADMIN)
// ============================================
enum AdminRole {
  SUPER_ADMIN  // 모든 권한
  ADMIN        // dept 내 권한
}

model Admin {
  id           String    @id @default(uuid())
  loginid      String    @unique
  role         AdminRole @default(ADMIN)
  deptname     String    @default("")
  businessUnit String?   @map("business_unit")
  designatedBy String?   @map("designated_by")  // 지정한 super admin loginid
  createdAt    DateTime  @default(now())

  models Model[]  // 등록한 모델들

  @@map("admins")
}

// ============================================
// 사용 로그 (개별 요청)
// ============================================
model UsageLog {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")        // nullable: background 서비스는 user 없음
  modelId      String   @map("model_id")
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  latencyMs    Int?     @map("latency_ms")
  timestamp    DateTime @default(now())
  deptname     String?                          // 요청 dept 추적

  // 서비스 연결
  serviceId String? @map("service_id")
  service   Service? @relation(fields: [serviceId], references: [id])

  user  User?  @relation(fields: [userId], references: [id])
  model Model @relation(fields: [modelId], references: [id])

  @@index([userId])
  @@index([modelId])
  @@index([timestamp])
  @@index([serviceId])
  @@index([deptname])
  @@index([userId, serviceId, timestamp])  // rate limit aggregate 최적화
  @@map("usage_logs")
}

// ============================================
// 일별 사용 통계 (집계)
// ============================================
model DailyUsageStat {
  id                String   @id @default(uuid())
  date              DateTime @db.Date
  userId            String?  @map("user_id")    // nullable: background
  modelId           String   @map("model_id")
  deptname          String   @default("")
  totalInputTokens  Int      @default(0)
  totalOutputTokens Int      @default(0)
  requestCount      Int      @default(0)

  serviceId String?  @map("service_id")
  service   Service? @relation(fields: [serviceId], references: [id])

  user  User?  @relation(fields: [userId], references: [id])
  model Model @relation(fields: [modelId], references: [id])

  @@unique([date, userId, modelId, serviceId])
  @@index([date])
  @@index([userId])
  @@index([modelId])
  @@index([serviceId])
  @@map("daily_usage_stats")
}

// ============================================
// 휴일 관리
// ============================================
enum HolidayType {
  NATIONAL
  COMPANY
  CUSTOM
}

model Holiday {
  id        String      @id @default(uuid())
  date      DateTime    @db.Date @unique
  name      String
  type      HolidayType @default(NATIONAL)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([date])
  @@map("holidays")
}

// ============================================
// 사용자별 토큰 Rate Limit
// ============================================
enum RateLimitWindow {
  FIVE_HOURS  // 5시간 윈도우
  DAY         // 24시간 윈도우
}

model UserRateLimit {
  id         String          @id @default(uuid())
  userId     String          @map("user_id")
  serviceId  String          @map("service_id")
  maxTokens  Int             @map("max_tokens")       // 윈도우 내 최대 토큰
  window     RateLimitWindow @default(DAY)
  enabled    Boolean         @default(true)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  createdBy  String?         @map("created_by")       // 설정한 admin loginid

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([serviceId])
  @@map("user_rate_limits")
}

// ============================================
// 모델 평점 피드백 (1-5점)
// ============================================
model RatingFeedback {
  id        String   @id @default(uuid())
  modelName String   @map("model_name")
  rating    Int
  timestamp DateTime @default(now())

  serviceId String?  @map("service_id")
  service   Service? @relation(fields: [serviceId], references: [id])

  @@index([modelName])
  @@index([timestamp])
  @@index([serviceId])
  @@map("rating_feedbacks")
}
